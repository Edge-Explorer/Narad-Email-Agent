# ════════════════════════════════════════════════
#   Narad Email Agent — .gitignore
#   Nothing sensitive should ever reach GitHub!
# ════════════════════════════════════════════════


# ── 🔐 CREDENTIALS & SECRETS (NEVER PUSH THESE) ─
.env
.env.*
*.env
!.env.example


# ── 🐍 Python Virtual Environment ────────────────
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/


# ── 🐍 Python Cache & Compiled Files ─────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python


# ── 📦 Distribution / Build ──────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/


# ── 🧪 Testing & Coverage ────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.cover
coverage.xml
nosetests.xml


# ── 🗂️ Logs & Temp Files ─────────────────────────
*.log
*.tmp
*.temp
logs/
temp/


# ── 💻 IDE & Editor Files ────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~


# ── 🖥️ OS Generated Files ────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini


# 📁 Project Specific ───────────────────────────
# Local database or cache used by the agent
*.db
*.sqlite
*.sqlite3
data/cache/

# 🔐 DevGuardian Security ───────────────────────
*.pem
*.key
*.p12
*.pfx
*.jks
secrets/
credentials/
.aws/
service-account*.json
*_rsa
*_dsa
*_ecdsa
*_ed25519

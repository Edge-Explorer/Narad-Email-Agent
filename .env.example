# ════════════════════════════════════════════════════════
#   Narad Email Agent — Environment Variables Template
#
#   HOW TO USE:
#   1. Copy this file and rename it to   .env
#   2. Fill in your actual values below
#   3. NEVER commit your .env file to GitHub!
# ════════════════════════════════════════════════════════


# ── Gmail Credentials ──────────────────────────────────
# Use a Gmail App Password, NOT your actual Gmail password.
# Steps to get App Password:
#   → Google Account → Security → 2-Step Verification → App Passwords
EMAIL_ADDRESS="your_email@gmail.com"
EMAIL_PASSWORD="your_16_digit_gmail_app_password"

# ── Gmail SMTP (for Sending) ───────────────────────────
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587

# ── Gmail IMAP (for Reading) ───────────────────────────
IMAP_SERVER="imap.gmail.com"

# ── Gemini API Key ─────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
